      <column caption='Patient Kpi status' datatype='string' name='[Calculation_1647191606351872000]' role='measure' type='nominal'>
        <calculation class='tableau' formula='if avg([Patient Satisfaction Score])&gt;=4 then &quot;Good&quot;&#13;&#10;&#13;&#10;else &quot;Average&quot;&#13;&#10;end' />
